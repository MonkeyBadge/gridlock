; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="maze-td"
config/description="A maze tower defense game"
run/main_scene="res://scenes/game/Game.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GridManager="*res://autoloads/GridManager.gd"
FlowFieldManager="*res://autoloads/FlowFieldManager.gd"
GameState="*res://autoloads/GameState.gd"
EnemyManager="*res://autoloads/EnemyManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="MazeTD"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")
